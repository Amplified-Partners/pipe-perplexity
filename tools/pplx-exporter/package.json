{
  "name": "@amplified/pplx-exporter",
  "version": "0.1.0",
  "description": "Perplexity conversation exporter — exports your threads to Markdown + JSON with full metadata",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "pplx-exporter": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "lint": "eslint src/ --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "export": "tsx src/index.ts"
  },
  "dependencies": {
    "playwright": "^1.44.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "tsx": "^4.15.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=18"
  },
  "author": "Amplified Partners",
  "license": "MIT"
}
